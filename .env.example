NEXT_PUBLIC_STELLAR_NETWORK=testnet

# User Storage Configuration
# Options: "file" (local development) or "database" (production)
DATA_STORE=file

# Database URL (required if DATA_STORE=database)
# Example for SQLite: file:./dev.db
# Example for PostgreSQL: postgresql://user:password@localhost:5432/payeasy
DATABASE_URL="file:./dev.db"

# JWT Configuration
# Token expiration time (default: 7d)
# Format: "7d", "24h", "1h", "30m", etc.
JWT_EXPIRY=7d

# Authentication Secret
# !!! CRITICAL: Must be changed for production !!!
# This is used to sign and verify JWT tokens.
# DO NOT use the placeholder value in production.
# Generate a new secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=payeasy-dev-secret-change-in-production-32chars

# Redis Configuration (optional)
# For production rate limiting with Upstash Redis
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
